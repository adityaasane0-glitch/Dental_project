<!--home page-->
<!DOCTYPE html>
<html lang="en">
<meta http-equiv="content-type" content="text/html;charset=utf-8" /><!-- /Added by HTTrack -->
<head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <!-- Bootstrap -->
        <link
            href="web/css/bootstrap.min.css"
            rel="stylesheet">

        <!-- Bootstrap Icons -->
        <link
            href="cdn.jsdelivr.net/npm/bootstrap-icons%401.11.1/font/bootstrap-icons.css"
            rel="stylesheet">

        <!-- Custom CSS -->
        <link rel="stylesheet" href="web/css/whyus.css">
        <link rel="stylesheet"
            href="cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/web/css/all.min.css">
        <link
            rel="stylesheet"
            href="cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/web/css/all.min.css" />

        <link rel="preconnect" href="https://fonts.googleapis.com/" />
        <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&amp;display=swap"
            rel="stylesheet" />
        <!--Aos -->
        <link rel="stylesheet"
            href="unpkg.com/aos%402.3.1/dist/aos.css" />

        <link rel="shortcut icon" href="web/img/download%20(35).png"
            type="image/x-icon">
        <title>Prime Dental</title>
    </head>
    <body>
        <!--header section -->
        <header>
            <!-- Navbar (اختياري) -->
            <nav class="navbar main-nav fixed-top py-3 navbar-expand-lg">
                <div
                    class="container d-flex justify-content-between align-items-center">

                    <!-- Logo -->
                    <div class="d-flex align-items-center gap-2 brand-logo">
                        <i class="fa-solid fa-tooth"></i>
                        <h4 class="fw-bold m-0 Logo">Prime Dental</h4>
                    </div>

                    <!-- Desktop Menu (visible on large screens only) -->
                    <ul class="nav d-none d-lg-flex">
                        <li class="nav-item"><a class="nav-link "
                                href="/">Home</a></li>
                        <li class="nav-item"><a class="nav-link "
                                href="/whyus">Why Us</a></li>
                        <li class="nav-item"><a class="nav-link "
                                href="/service">Services</a></li>
                        <li class="nav-item"><a class="nav-link "
                                href="/team">Team</a></li>
                        <li class="nav-item"><a class="nav-link"
                                href="/Pricing">Pricing</a></li>
                        <li class="nav-item"><a class="nav-link"
                                href="/DentalSolutions">Solutions</a></li>
                    </ul>

                    <a href="#"
                        class="btn px-4 d-none d-lg-block">Book
                        Now</a>

                    <!-- Burger Button (Mobile Only) -->
                    <button class="navbar-toggler d-lg-none"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#mobileMenu">

                        <i class="bi bi-list fs-1"></i>
                    </button>

                </div>
            </nav>

            <!-- Offcanvas Mobile Menu -->
            <div class="offcanvas offcanvas-end" id="mobileMenu"
                style="background-color: #8a7aff;">

                <div class="offcanvas-header">
                    <div class="d-flex align-items-center gap-2 brand-logo">
                        <i class="fa-solid fa-tooth"></i>
                        <h4 class="fw-bold m-0">Prime Dental</h4>
                    </div>

                    <button class="btn-close"
                        data-bs-dismiss="offcanvas"></button>
                </div>

                <div class="offcanvas-body">

                    <ul class="navbar-nav gap-2">

                        <li><a class="nav-link" href="/">Home</a></li>
                        <li><a class="nav-link" href="/whyus">Why
                                Us</a></li>
                        <li><a class="nav-link"
                                href="/service">Services</a></li>
                        <li><a class="nav-link" href="/team">Team</a></li>
                        <li><a class="nav-link"
                                href="/Pricing">Pricing</a></li>
                        <li><a class="nav-link"
                                href="/DentalSolutions">Solutions</a></li>

                    </ul>

                    <a class="btn w-100 mt-3">Book Now</a>

                </div>

            </div>
        </header>
        <!-- hero section-->
        <section class="hero-section d-flex align-items-center">
            <div class="container text-center">

                <h1 class="hero-title">
                    Why Choose Prime Dental?
                </h1>

                <p class="hero-text">
                    We provide trusted, compassionate and high-quality dental
                    care
                    to ensure your comfort and confidence.
                </p>

                <a href="#" class="btn hero-btn px-5 py-2">
                    Book an Appointment
                </a>

            </div>
        </section>
        <!--why us section-->
        <section class="container py-5">

            <div class="row align-items-center g-4">

                <!-- Image Column -->
                <div class="col-md-5">
                    <img src="web/img/whyus.jpg"
                        class="why-img">
                </div>

                <!-- Text Column -->
                <div class="col-md-7">

                    <h2 class="fw-bold mb-2">Why Choose Prime Dental?</h2>

                    <p class="text-muted mb-3">
                        At Prime Dental, we focus on delivering accurate,
                        comfortable, and
                        high-quality dental care using modern technology and
                        experienced medical
                        standards. Our team works with care and transparency to
                        provide personalized
                        treatment plans and a friendly clinical environment
                        where patients feel safe,
                        confident, and supported throughout their dental
                        journey.
                    </p>

                    <ul class="why-list">

                        <li>
                            <i class="bi bi-check-circle-fill"></i>
                            Certified & highly-qualified dentists
                        </li>

                        <li>
                            <i class="bi bi-check-circle-fill"></i>
                            Modern technology & advanced dental equipment
                        </li>

                        <li>
                            <i class="bi bi-check-circle-fill"></i>
                            Friendly & patient-centered treatment experience
                        </li>

                        <li>
                            <i class="bi bi-check-circle-fill"></i>
                            Affordable treatment plans & flexible appointments
                        </li>

                    </ul>

                </div>

            </div>

        </section>
        <!--appointment container-->
        <section class="container my-5">

            <div class="row align-items-stretch g-0 no-gap">

                <!-- Text Column (With Background & Circles) -->
                <div class="col-md-7">
                    <div class="appointment-box p-5">

                        <h3 class="fw-bold text-white">
                            Your Smile is Our Priority
                        </h3>

                        <p class="text-white-50">
                            Book your visit and let our team take care of your
                            dental health.
                        </p>

                        <a class="btn btn-light px-4 fw-semibold">
                            Book an Appointment
                        </a>

                    </div>
                </div>

                <!-- Image Column -->
                <div class="col-md-5">
                    <img
                        src="web/img/whyusapp.jpg"
                        class="equal-img">
                </div>

            </div>

        </section>
  <%- include('footer.ejs') %>
